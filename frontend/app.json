{
  "expo": {
    "name": "robotech club app",
    "slug": "robotech-club-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGOCLUB.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LOGOCLUB.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.frontend"
    },
    "web": {
      "favicon": "./assets/LOGOCLUB.png"
    },
    "extra": {
      "eas": {
        "projectId": "efdb9f28-800c-4cef-bc61-9e63a522d1b4"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "owner": "skinnydevil"
  }
}
